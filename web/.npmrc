# Shared store at repo root (`../.pnpm-store`). Compose bind-mounts `./.pnpm-store` -> `/.pnpm-store` for web/api-node services (see docker-compose.yml).
store-dir=../.pnpm-store

# Pin exact versions on `pnpm add` (no ^ or ~ ranges).
save-exact=true

# Fail install when Node.js or pnpm does not match `package.json` `engines`.
engine-strict=true

# Fail install when peer dependencies are missing or incompatible.
strict-peer-dependencies=true
