{
  "name": "api-node",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": "24.14.1",
    "pnpm": "10.33.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "node --watch src/main.ts",
    "start": "node src/main.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "biome check .",
    "format": "biome check --write .",
    "test": "node --test test/**/*.test.ts"
  },
  "dependencies": {
    "@fastify/cors": "11.1.0",
    "fastify": "5.6.2",
    "pino": "10.3.1",
    "postgres": "3.4.7",
    "test-leakage-attack-node": "1.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.9",
    "@types/node": "24.12.0",
    "typescript": "6.0.2"
  }
}
